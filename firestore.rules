rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /siteContent/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /services/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /rates/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
